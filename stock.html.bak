<script>
document.getElementById('hamburger').addEventListener('click',function(){
  document.getElementById('mobileMenu').classList.toggle('open');
  this.textContent=document.getElementById('mobileMenu').classList.contains('open')?'✕':'☰';
});

async function fetchTicker(symbol) {
  const urls = [
    `https://query1.finance.yahoo.com/v8/finance/chart/${symbol}?interval=1d&range=1d`,
    `https://query2.finance.yahoo.com/v8/finance/chart/${symbol}?interval=1d&range=1d`
  ];
  for (const url of urls) {
    try {
      const r = await fetch(url);
      if (!r.ok) continue;
      const d = await r.json();
      const meta = d.chart.result[0].meta;
      const price = meta.regularMarketPrice;
      const prev = meta.previousClose || meta.chartPreviousClose;
      const change = ((price - prev)/prev*100).toFixed(2);
      return { price, change: parseFloat(change) };
    } catch(e){}
  }
  return null;
}

const stocks = [
  {id:'acwi', symbol:'ACWI'},
  {id:'nasdaq', symbol:'%5EIXIC'},
  {id:'sp500', symbol:'%5EGSPC'},
  {id:'ta125', symbol:'%5ETA125.TA'}
];

async function loadStocks() {
  for (const s of stocks) {
    const data = await fetchTicker(s.symbol);
    const pe = document.getElementById('s-'+s.id+'-price');
    const ce = document.getElementById('s-'+s.id+'-change');
    if (data) {
      pe.textContent = data.price.toLocaleString('en-US',{maximumFractionDigits:2});
      const sign = data.change >= 0 ? '+' : '';
      ce.textContent = sign + data.change + '%';
      ce.className = 'market-card-change ' + (data.change >= 0 ? 'positive' : 'negative');
    } else {
      pe.textContent = '—';
      ce.textContent = 'לא זמין';
      ce.className = 'market-card-change';
      ce.style.color = 'rgba(255,255,255,0.4)';
    }
  }
}
loadStocks();
setInterval(loadStocks, 60000);

const observer=new IntersectionObserver((e)=>{e.forEach(x=>{if(x.isIntersecting)x.target.classList.add('visible')})},{threshold:0.08});
document.querySelectorAll('.fade-in').forEach(el=>observer.observe(el));
const _p=document.createElement('div');_p.style.cssText='position:fixed;top:0;right:0;height:3px;background:linear-gradient(90deg,#FFF100,#00E5FF);z-index:9999;width:0;pointer-events:none';document.body.prepend(_p);
window.addEventListener('scroll',()=>{const s=document.documentElement;_p.style.width=(s.scrollTop/(s.scrollHeight-s.clientHeight)*100)+'%'});
const _f=document.createElement('a');_f.href='premium.html';_f.textContent='💰 להתחיל';_f.style.cssText='position:fixed;bottom:28px;left:28px;background:#FFF100;color:#0b1628;font-weight:900;font-family:Heebo,sans-serif;padding:14px 22px;border-radius:50px;font-size:0.95rem;box-shadow:0 4px 20px rgba(255,241,0,0.4);z-index:900;text-decoration:none;opacity:0;pointer-events:none;transition:all 0.3s';document.body.appendChild(_f);
const _t=document.createElement('button');_t.textContent='↑';_t.style.cssText='position:fixed;bottom:28px;right:28px;width:46px;height:46px;background:rgba(0,229,255,0.15);border:1px solid rgba(0,229,255,0.4);border-radius:50%;color:#00E5FF;font-size:1.2rem;cursor:pointer;z-index:900;opacity:0;pointer-events:none;transition:all 0.3s';document.body.appendChild(_t);
window.addEventListener('scroll',()=>{const s=window.scrollY>400;[_f,_t].forEach(e=>{e.style.opacity=s?'1':'0';e.style.pointerEvents=s?'auto':'none'})});
_t.addEventListener('click',()=>window.scrollTo({top:0,behavior:'smooth'}));
_f.addEventListener('mouseover',()=>{_f.style.transform='translateY(-3px) scale(1.05)'});_f.addEventListener('mouseout',()=>{_f.style.transform=''});
_t.addEventListener('mouseover',()=>{_t.style.background='rgba(0,229,255,0.3)'});_t.addEventListener('mouseout',()=>{_t.style.background='rgba(0,229,255,0.15)'});
</script>
</body>
</html>
