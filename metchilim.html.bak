<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>מתחילים לנפח - מנפחים ת'כיס</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;700;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#0b1628;--yellow:#FFF100;--neon:#00E5FF;--text:#fff;--card:#111f38;--font:'Heebo',sans-serif}
body{background:var(--bg);color:var(--text);font-family:var(--font);direction:rtl;overflow-x:hidden}
a{text-decoration:none;color:inherit}
nav{position:fixed;top:0;width:100%;background:rgba(11,22,40,0.95);backdrop-filter:blur(10px);z-index:1000;border-bottom:1px solid rgba(0,229,255,0.2);padding:0 20px}
.nav-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:65px}
.logo{font-size:1.4rem;font-weight:900;color:var(--yellow)}
.nav-links{display:flex;gap:8px;list-style:none;align-items:center}
.nav-links a{font-size:0.85rem;padding:6px 10px;border-radius:6px;transition:all 0.2s;color:rgba(255,255,255,0.85)}
.nav-links a:hover{color:var(--neon)}
.nav-links a.active{color:var(--yellow);font-weight:700}
.nav-cta{background:var(--yellow);color:#0b1628!important;font-weight:700;padding:8px 18px!important;border-radius:8px}
.hamburger{display:none;background:none;border:none;color:var(--text);font-size:1.6rem;cursor:pointer}
.mobile-menu{display:none;flex-direction:column;background:rgba(11,22,40,0.98);padding:20px;gap:10px}
.mobile-menu a{display:block;padding:12px 16px;border-radius:8px;border:1px solid rgba(0,229,255,0.15);color:var(--text);font-size:1rem;transition:all 0.2s}
.mobile-menu a:hover{background:rgba(0,229,255,0.1);color:var(--neon)}
.mobile-menu.open{display:flex}
@media(max-width:768px){.nav-links{display:none}.hamburger{display:block}}

/* HERO */
.hero{min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;position:relative;overflow:hidden;padding:100px 20px 60px}
.hero-bg{position:absolute;inset:0;background:linear-gradient(135deg,#0d2040 0%,#0b1628 60%,#0a1a30 100%)}
.hero-particles{position:absolute;inset:0;overflow:hidden}
.hero-particles span{position:absolute;border-radius:50%;animation:float linear infinite}
.hero-content{position:relative;z-index:1;max-width:800px}
.hero-badge{display:inline-block;background:rgba(255,241,0,0.1);border:1px solid rgba(255,241,0,0.3);border-radius:50px;padding:8px 20px;font-size:0.85rem;color:var(--yellow);margin-bottom:24px}
.hero h1{font-size:clamp(2.5rem,6vw,4.5rem);font-weight:900;line-height:1.1;margin-bottom:20px}
.hero h1 span{color:var(--yellow)}
.hero p{font-size:clamp(1rem,2vw,1.2rem);color:rgba(255,255,255,0.75);line-height:1.7}
@keyframes float{0%{transform:translateY(100vh) rotate(0deg);opacity:0}10%{opacity:1}90%{opacity:1}100%{transform:translateY(-100px) rotate(360deg);opacity:0}}

/* STATS */
.stats-section{padding:60px 20px;background:rgba(0,229,255,0.03);border-bottom:1px solid rgba(0,229,255,0.1)}
.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;max-width:1000px;margin:0 auto}
@media(max-width:768px){.stats-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:400px){.stats-grid{grid-template-columns:1fr}}
.stat-card{background:var(--card);border:1px solid rgba(0,229,255,0.2);border-radius:16px;padding:28px 20px;text-align:center;transition:all 0.3s}
.stat-card:hover{transform:translateY(-4px);border-color:var(--neon);box-shadow:0 0 25px rgba(0,229,255,0.1)}
.stat-number{font-size:clamp(1.6rem,3vw,2.2rem);font-weight:900;color:var(--yellow);margin-bottom:8px}
.stat-label{font-size:0.85rem;color:rgba(255,255,255,0.6);line-height:1.4}

/* SECTIONS */
section{padding:80px 20px}
.container{max-width:1100px;margin:0 auto}
.section-title{font-size:clamp(1.8rem,3.5vw,2.5rem);font-weight:900;color:var(--yellow);margin-bottom:12px}
.section-subtitle{font-size:1rem;color:rgba(255,255,255,0.65);margin-bottom:40px;line-height:1.6}

/* COMPOUND TRAP */
.trap-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:30px}
@media(max-width:768px){.trap-cards{grid-template-columns:1fr}}
.trap-card{background:var(--card);border:1px solid rgba(255,241,0,0.2);border-radius:16px;padding:28px;text-align:center}
.trap-card-num{font-size:2rem;font-weight:900;color:var(--yellow);margin-bottom:8px}
.trap-card-label{font-size:0.85rem;color:rgba(255,255,255,0.6)}

/* WHAT YOU GET */
.features-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
@media(max-width:900px){.features-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:550px){.features-grid{grid-template-columns:1fr}}
.feature-card{background:var(--card);border:1px solid rgba(0,229,255,0.2);border-radius:16px;padding:28px;transition:all 0.3s}
.feature-card:hover{transform:translateY(-4px);border-color:var(--neon);box-shadow:0 0 25px rgba(0,229,255,0.1)}
.feature-icon{font-size:2rem;margin-bottom:12px}
.feature-title{font-size:1rem;font-weight:700;color:var(--neon);margin-bottom:8px}
.feature-desc{font-size:0.85rem;color:rgba(255,255,255,0.6);line-height:1.6}

/* COST CALCULATOR */
.cost-calc{background:var(--card);border:1px solid rgba(0,229,255,0.25);border-radius:20px;padding:40px;max-width:600px;margin:0 auto}
.cost-calc h3{font-size:1.4rem;font-weight:900;color:var(--yellow);margin-bottom:8px}
.cost-calc p{font-size:0.9rem;color:rgba(255,255,255,0.6);margin-bottom:30px}
.slider-group{margin-bottom:24px}
.slider-label{display:flex;justify-content:space-between;font-size:0.85rem;color:rgba(255,255,255,0.7);margin-bottom:8px;font-weight:700}
.slider-label span:last-child{color:var(--yellow)}
input[type="range"]{width:100%;accent-color:var(--yellow);height:6px;cursor:pointer}
.cost-result{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:20px}
.cost-box{background:rgba(0,0,0,0.3);border-radius:12px;padding:20px;text-align:center}
.cost-box.saving{border:1px solid rgba(0,255,136,0.3)}
.cost-box.paying{border:1px solid rgba(255,68,102,0.3)}
.cost-box-label{font-size:0.8rem;color:rgba(255,255,255,0.5);margin-bottom:6px}
.cost-box-val{font-size:1.4rem;font-weight:900}
.cost-box.saving .cost-box-val{color:#00ff88}
.cost-box.paying .cost-box-val{color:#ff4466}

/* FIT/NOT FIT */
.fit-grid{display:grid;grid-template-columns:1fr 1fr;gap:30px}
@media(max-width:768px){.fit-grid{grid-template-columns:1fr}}
.fit-card{background:var(--card);border-radius:16px;padding:30px}
.fit-card.yes{border:1px solid rgba(0,255,136,0.3)}
.fit-card.no{border:1px solid rgba(255,68,102,0.3)}
.fit-title{font-size:1.1rem;font-weight:900;margin-bottom:20px;padding-bottom:12px;border-bottom:1px solid rgba(255,255,255,0.08)}
.fit-card.yes .fit-title{color:#00ff88}
.fit-card.no .fit-title{color:#ff4466}
.fit-list{list-style:none;display:flex;flex-direction:column;gap:12px}
.fit-list li{font-size:0.9rem;color:rgba(255,255,255,0.8);line-height:1.5;padding-right:8px}

.fade-in{opacity:0;transform:translateY(30px);transition:opacity 0.7s ease,transform 0.7s ease}
.fade-in.visible{opacity:1;transform:translateY(0)}

/* FOOTER */
footer{background:#080e1a;border-top:1px solid rgba(0,229,255,0.1);padding:50px 20px 30px}
.footer-inner{max-width:1200px;margin:0 auto}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr;gap:40px;margin-bottom:40px}
@media(max-width:768px){.footer-top{grid-template-columns:1fr}}
.footer-logo{font-size:1.6rem;font-weight:900;color:var(--yellow);margin-bottom:12px}
.footer-desc{font-size:0.9rem;color:rgba(255,255,255,0.5);line-height:1.7}
.footer-col h4{font-size:0.9rem;font-weight:700;color:var(--neon);margin-bottom:16px}
.footer-col ul{list-style:none;display:flex;flex-direction:column;gap:10px}
.footer-col ul a{font-size:0.85rem;color:rgba(255,255,255,0.55);transition:color 0.2s}
.footer-col ul a:hover{color:var(--yellow)}
.footer-bottom{border-top:1px solid rgba(255,255,255,0.06);padding-top:24px}
.footer-copy{font-size:0.8rem;color:rgba(255,255,255,0.3)}
.disclaimer{font-size:0.75rem;color:rgba(255,255,255,0.35);line-height:1.5;margin-top:8px}

        /* ══ FLOATING LOGO ══ */
        .logo-container{position:relative;width:90px;height:90px;margin:0 auto 24px;cursor:pointer;}
        .logo-ring{position:absolute;inset:-10px;border-radius:50%;border:2px solid transparent;background:linear-gradient(var(--dark),var(--dark)) padding-box,conic-gradient(var(--yellow),var(--blue),var(--yellow2),var(--blue2),var(--yellow)) border-box;animation:spinRing 4s linear infinite;}
        @keyframes spinRing{to{transform:rotate(360deg);}}
        .logo-glow-outer{position:absolute;inset:-18px;border-radius:50%;background:radial-gradient(circle,rgba(250,204,21,0.15) 0%,rgba(14,165,233,0.1) 50%,transparent 70%);animation:glowPulse 2.5s ease-in-out infinite;}
        @keyframes glowPulse{0%,100%{transform:scale(1);opacity:0.7;}50%{transform:scale(1.15);opacity:1;}}
        .hero-logo{width:90px;height:90px;border-radius:50%;object-fit:cover;border:3px solid var(--yellow);display:block;position:relative;z-index:2;animation:logoFloat 3s ease-in-out infinite;transition:all 0.3s ease;filter:drop-shadow(0 0 20px rgba(250,204,21,0.4));}
        @keyframes logoFloat{0%,100%{transform:translateY(0px);filter:drop-shadow(0 0 20px rgba(250,204,21,0.4)) drop-shadow(0 0 40px rgba(14,165,233,0.2));}50%{transform:translateY(-12px);filter:drop-shadow(0 0 30px rgba(250,204,21,0.7)) drop-shadow(0 0 60px rgba(14,165,233,0.4));}}
        .logo-container:hover .hero-logo{filter:drop-shadow(0 0 25px rgba(250,204,21,0.9)) drop-shadow(0 0 50px rgba(14,165,233,0.7));transform:scale(1.08) translateY(-6px);border-color:var(--blue2);}
        .logo-container:hover .logo-ring{animation:spinRing 1s linear infinite;}
        .logo-container:hover .logo-glow-outer{background:radial-gradient(circle,rgba(14,165,233,0.35) 0%,rgba(250,204,21,0.2) 50%,transparent 70%);}
        .nav-logo-text{font-size:1.1rem;font-weight:900;}
        .nav-logo-text .blue{color:#38bdf8;}
        .nav-logo-text .yellow{color:#facc15;}

        </style>
</head>
<body>

<nav>
  <div class="nav-inner">
    <a href="index.html" class="logo"><img src="logo.jpg" alt="מנפחים ת'כיס" style="height:38px;width:auto;vertical-align:middle;border-radius:6px;"></a>
    <ul class="nav-links">
      <li><a href="index.html">בית</a></li>
      <li><a href="metchilim.html" class="active">מתחילים לנפח</a></li>
      <li><a href="psychology.html">פסיכולוגיה</a></li>
      <li><a href="assets.html">נכסים</a></li>
      <li><a href="bankayt.html">בנקאית</a></li>
      <li><a href="stock.html">שוק ההון</a></li>
      <li><a href="protocol.html">פרוטוקול ה-10</a></li>
      <li><a href="premium.html" class="nav-cta">מנפחים מתקדמים</a></li>
    </ul>
    <button class="hamburger" id="hamburger">☰</button>
  </div>
  <div class="mobile-menu" id="mobileMenu">
    <a href="index.html">🏠 בית</a>
    <a href="metchilim.html">🚀 מתחילים לנפח</a>
    <a href="psychology.html">🧠 פסיכולוגיה</a>
    <a href="assets.html">💎 נכסים</a>
    <a href="bankayt.html">🏦 בנקאית</a>
    <a href="stock.html">📈 שוק ההון</a>
    <a href="protocol.html">✈️ פרוטוקול ה-10</a>
    <a href="premium.html" style="color:#FFF100;border-color:rgba(255,241,0,0.4)">⭐ מנפחים מתקדמים</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"></div>
  <div class="hero-content fade-in">
    <div class="hero-badge">המדריך שצריכים לדעת 🚀</div>
    <h1>מתחילים <span>לנפח</span></h1>
    <p>המדריך שצריך לדעת כדי להתחיל: בלי עמלות מיותרות, בלי בנקים שיאכלו לכם את הרווחים</p>
  </div>
</section>

<!-- STATS -->
<div class="stats-section">
  <div class="stats-grid fade-in">
    <div class="stat-card">
      <div class="stat-number" data-count="199" data-prefix="₪">₪0</div>
      <div class="stat-label">מחיר המדריך המלא</div>
    </div>
    <div class="stat-card">
      <div class="stat-number" data-count="0.8" data-suffix="%" data-decimal="1">0%</div>
      <div class="stat-label">דמי ניהול ממוצעים לחסכונות</div>
    </div>
    <div class="stat-card">
      <div class="stat-number" data-count="58000" data-prefix="₪">₪0</div>
      <div class="stat-label">חסכון ממוצע של ישראלי</div>
    </div>
    <div class="stat-card">
      <div class="stat-number" data-count="100" data-prefix="₪" data-suffix="K">₪0K</div>
      <div class="stat-label">היעד הראשון שצריך לדעת</div>
    </div>
  </div>
</div>

<!-- COMPOUND TRAP -->
<section>
  <div class="container fade-in">
    <h2 class="section-title">הריבית דריבית לא מחכה לך</h2>
    <p class="section-subtitle">בבנק: יש מציאות אחת: כל כסף שיושב שם, לא באמת עובד בשבילך. בזמן שהבנק מציע לך 0.02%, האינפלציה גונבת לך 3% בשנה. כלומר: אתה מפסיד כסף כל שנה שאתה מחכה.</p>
    <div class="trap-cards">
      <div class="trap-card">
        <div class="trap-card-num">0.85%</div>
        <div class="trap-card-label">דמי עו"ש שאתה לא שם לב אליהם</div>
      </div>
      <div class="trap-card">
        <div class="trap-card-num">₪58,000</div>
        <div class="trap-card-label">חסכון ממוצע של ישראלי: מה שנשאר אחרי שהמערכת לקחה</div>
      </div>
      <div class="trap-card">
        <div class="trap-card-num">₪1,000,000</div>
        <div class="trap-card-label">מה שיכולת לצבור בחיסכון מגיל 16 עם ₪300/חודש</div>
      </div>
    </div>
  </div>
</section>

<!-- WHAT YOU GET -->
<section style="background:linear-gradient(135deg,#0d2040 0%,#0b1628 100%)">
  <div class="container">
    <div class="fade-in" style="text-align:center;margin-bottom:40px">
      <h2 class="section-title">מה תקבל בפועל</h2>
      <p class="section-subtitle">לא הבטחות ריקות. כלים אמיתיים שישנו את הדרך שבה אתה מסתכל על כסף.</p>
    </div>
    <div class="features-grid fade-in">
      <div class="feature-card">
        <div class="feature-icon">📊</div>
        <div class="feature-title">ACWI / S&P 500 / SPTECH</div>
        <div class="feature-desc">השוואה אמיתית בין הקרנות הגדולות בעולם: מה מתאים לך ולמה</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🎯</div>
        <div class="feature-title">המדריך שלי: Cheat Code לחיים</div>
        <div class="feature-desc">הצעד הראשון ל-S&P 500, שלב אחרי שלב, בעברית מלאה</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📅</div>
        <div class="feature-title">פרוטוקול ה-10 לחודש</div>
        <div class="feature-desc">תוכנית שניתן לבצע בתוך 20 דקות ביום ה-10 בכל חודש</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📱</div>
        <div class="feature-title">מדריך חשבון מסחר</div>
        <div class="feature-desc">מדריך צילומי לפתיחת חשבון מסחר: צד אחר צד</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">💳</div>
        <div class="feature-title">הכנסות פסיביות</div>
        <div class="feature-desc">דרכים פסיביות לייצור הכנסה בתנאי השוק הישראלי</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">💡</div>
        <div class="feature-title">בסיס לפיננסים</div>
        <div class="feature-desc">כל המושגים שצריך לדעת לפני שנוגעים בשקל: הסבר ברור ופשוט</div>
      </div>
    </div>
  </div>
</section>

<!-- COST CALCULATOR -->
<section>
  <div class="container">
    <div class="fade-in" style="text-align:center;margin-bottom:40px">
      <h2 class="section-title">כמה עולה לך לא לדעת</h2>
      <p class="section-subtitle">השוואה בין קרן רגילה לקרן אירית: כמה כסף אתה מפסיד על עמלות מיותרות</p>
    </div>
    <div class="cost-calc fade-in">
      <h3>מחשבון חיסכון בעמלות</h3>
      <p>השווה בין ניהול פעיל (דמי ניהול גבוהים) לבין ETF עולמי</p>
      <div class="slider-group">
        <div class="slider-label">
          <span>תקופת השקעה</span>
          <span id="yearsDisplay">20 שנים</span>
        </div>
        <input type="range" id="yearsRange" min="5" max="40" value="20">
      </div>
      <div class="slider-group">
        <div class="slider-label">
          <span>סכום חודשי</span>
          <span id="monthlyDisplay">₪1,000</span>
        </div>
        <input type="range" id="monthlyRange" min="200" max="5000" value="1000" step="100">
      </div>
      <div class="cost-result">
        <div class="cost-box paying">
          <div class="cost-box-label">קרן רגילה (1.5% דמי ניהול)</div>
          <div class="cost-box-val" id="highFeeResult">₪0</div>
        </div>
        <div class="cost-box saving">
          <div class="cost-box-label">קרן אירית / ETF (0.07% דמי ניהול)</div>
          <div class="cost-box-val" id="lowFeeResult">₪0</div>
        </div>
      </div>
      <div style="text-align:center;margin-top:16px;font-size:0.9rem;color:rgba(255,255,255,0.6)">
        ההפרש: <span id="diffResult" style="color:var(--yellow);font-weight:900;font-size:1.1rem">₪0</span>
      </div>
    </div>
  </div>
</section>

<!-- FIT / NOT FIT -->
<section style="background:linear-gradient(135deg,#0d2040 0%,#0b1628 100%)">
  <div class="container">
    <div class="fade-in" style="text-align:center;margin-bottom:40px">
      <h2 class="section-title">למי זה מתאים: ולמי לא</h2>
      <p class="section-subtitle">שקיפות מלאה: כי אנחנו לא רוצים למכור לכם משהו שלא מתאים לכם</p>
    </div>
    <div class="fit-grid fade-in">
      <div class="fit-card yes">
        <div class="fit-title">✅ המדריך בשבילך אם...</div>
        <ul class="fit-list">
          <li>✅ אתה צעיר ורוצה שהכסף יעבוד בשבילך מהיום</li>
          <li>✅ רוצה להבין מה זה S&P 500 ולמה כולם מדברים עליו</li>
          <li>✅ שמעת על "קרן אירית" ולא ידעת מה זה</li>
          <li>✅ רוצה להשקיע אבל לא יודע מאיפה להתחיל</li>
          <li>✅ נמאס לך שהבנק לוקח עמלות על כל פרוטה</li>
          <li>✅ רוצה לבנות עתיד פיננסי עצמאי</li>
        </ul>
      </div>
      <div class="fit-card no">
        <div class="fit-title">❌ המדריך לא בשבילך אם...</div>
